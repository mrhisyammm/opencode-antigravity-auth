{
    "name": "@mrhisyammm/opencode-antigravity-auth",
    "version": "1.0.0",
    "publishConfig": {
        "access": "public"
    },
    "description": "Google Antigravity IDE OAuth auth plugin for Opencode - access Gemini 3 Pro and Claude 4.6 using Google credentials",
    "main": "./dist/bundle.js",
    "type": "module",
    "license": "MIT",
    "author": "noefabris",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mrhisyammm/opencode-antigravity-auth.git"
    },
    "homepage": "https://github.com/mrhisyammm/opencode-antigravity-auth#readme",
    "bugs": {
        "url": "https://github.com/mrhisyammm/opencode-antigravity-auth/issues"
    },
    "keywords": [
        "opencode",
        "google",
        "antigravity",
        "gemini",
        "oauth",
        "plugin",
        "auth",
        "claude"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "files": [
        "dist/bundle.js",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:schema": "npx tsx script/build-schema.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build",
        "test:e2e:models": "npx tsx script/test-models.ts",
        "test:e2e:regression": "npx tsx script/test-regression.ts"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "@types/proper-lockfile": "^4.1.4",
        "@vitest/coverage-v8": "^3.0.0",
        "@vitest/ui": "^3.0.0",
        "typescript": "^5.0.0",
        "vitest": "^3.0.0",
        "zod-to-json-schema": "^3.25.1"
    },
    "dependencies": {}
}